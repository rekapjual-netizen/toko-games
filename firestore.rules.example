rules_version = '2';

// Terapkan di Firebase Console: Firestore Database > Rules
// (project "toko-qris"). Aturan ini dipakai bareng oleh app
// PWA-Kasir (publik) dan app Admin (login).
service cloud.firestore {
  match /databases/{database}/documents {

    // Produk, banner, settings QRIS: siapa saja boleh BACA (dipakai kasir),
    // tapi hanya admin yang sudah login yang boleh UBAH.
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /banners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Order: siapa saja boleh BUAT order baru (checkout dari kasir), dan
    // boleh membaca SATU order miliknya sendiri via ID (untuk halaman
    // checkout) — ID order acak jadi tidak bisa ditebak orang lain.
    // Tapi TIDAK BOLEH melihat daftar semua order / mengubah / menghapus.
    // Hanya admin yang boleh melihat daftar order & update status jadi "Lunas".
    match /orders/{docId} {
      allow create: if true;
      allow get: if true;
      allow list: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
